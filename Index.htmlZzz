<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>saammrgy | Hub</title>
    <style>
        :root {
            --bg-base: #000000;
            --accent-green: #073322;
            --glow-green: #00ff88;
            --glass: rgba(7, 51, 34, 0.25);
            --text-main: #ffffff;
            --text-dim: #8892b0;
        }

        /* Infinity Edge & Animated Background */
        body {
            background-color: var(--bg-base);
            margin: 0;
            padding: 20px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            font-family: 'Inter', -apple-system, sans-serif;
            color: var(--text-main);
            /* This creates the dark infinite edges */
            box-shadow: inset 0 0 150px rgba(0,0,0,0.9);
            overflow-x: hidden;
            animation: breathe 8s infinite alternate ease-in-out;
        }

        @keyframes breathe {
            0% { background-image: radial-gradient(circle at 50% 0%, var(--accent-green), transparent 500px); }
            100% { background-image: radial-gradient(circle at 50% 10%, #0a4d33, transparent 700px); }
        }

        .container {
            max-width: 500px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* Glitch/Neon Header Effect */
        header {
            text-align: center;
            margin: 40px 0 30px;
        }

        .header-pfp {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            border: 3px solid var(--glow-green);
            background-color: var(--accent-green); /* Fallback color if image breaks */
            object-fit: cover;
            box-shadow: 0 0 25px rgba(0, 255, 136, 0.3);
            margin-bottom: 15px;
            transition: transform 0.3s;
        }

        .header-pfp:hover {
            transform: scale(1.05);
        }

        h1 {
            font-size: 2.2rem;
            letter-spacing: -1px;
            margin: 0;
            color: #fff;
            text-shadow: 0 0 10px var(--glow-green);
        }

        /* Glassmorphism Sections */
        .section-card {
            background: var(--glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 255, 136, 0.1);
            border-radius: 20px;
            padding: 22px;
            margin-bottom: 25px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .section-card:hover {
            border-color: rgba(0, 255, 136, 0.3);
            box-shadow: 0 10px 40px rgba(7, 51, 34, 0.8);
        }

        .profile-header {
            display: flex;
            align-items: center;
            margin-bottom: 18px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 10px;
        }

        .username {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--glow-green);
        }

        /* Unbreakable CSS TikTok Thumbnails */
        .video-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }

        .video-link {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            text-decoration: none;
            border-radius: 12px;
            border: 1px solid rgba(0,255,136,0.2);
            aspect-ratio: 9 / 16;
            background: linear-gradient(135deg, #02120c, var(--accent-green));
            transition: all 0.2s ease;
            overflow: hidden;
        }

        /* Click & Hover Effects for Videos */
        .video-link:hover {
            border-color: var(--glow-green);
            box-shadow: 0 0 15px rgba(0,255,136,0.4);
        }
        .video-link:active {
            transform: scale(0.92);
        }

        .play-icon {
            color: rgba(255,255,255,0.9);
            font-size: 2rem;
            text-shadow: 0 0 10px #000;
        }

        /* Interactive Buttons */
        .action-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(0,255,136,0.15);
            padding: 16px;
            border-radius: 14px;
            color: var(--text-main);
            text-decoration: none;
            transition: all 0.2s ease;
            font-size: 0.95rem;
            font-weight: 500;
            margin-top: 10px;
        }

        /* The Click "Squish" Effect */
        .action-link:hover {
            background: var(--accent-green);
            border-color: var(--glow-green);
            color: #fff;
        }
        .action-link:active {
            transform: scale(0.96);
            box-shadow: 0 0 20px var(--glow-green);
        }

        /* Custom AniList Tags */
        .manga-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
        }

        .tag {
            background: rgba(0, 255, 136, 0.1);
            color: var(--glow-green);
            border: 1px solid var(--glow-green);
            padding: 5px 10px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        footer {
            text-align: center;
            padding: 20px;
            color: var(--text-dim);
            font-size: 0.75rem;
            letter-spacing: 1px;
            opacity: 0.6;
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <img src="pfp.png" class="header-pfp" alt="?" onerror="this.style.display='none'">
            <h1>saammrgy</h1>
        </header>

        <div class="section-card">
            <div class="profile-header">
                <div class="username">@saamrgy (TikTok)</div>
            </div>
            <div class="video-grid">
                <a href="https://vt.tiktok.com/ZSu7kPJFP/" target="_blank" class="video-link">
                    <span class="play-icon">▶</span>
                </a>
                <a href="https://vt.tiktok.com/ZSu7kGJQj/" target="_blank" class="video-link">
                    <span class="play-icon">▶</span>
                </a>
                <a href="https://vt.tiktok.com/ZSu7kcQMg/" target="_blank" class="video-link">
                    <span class="play-icon">▶</span>
                </a>
            </div>
        </div>

        <div class="section-card">
            <div class="profile-header">
                <div class="username">@saammrgy (Instagram)</div>
            </div>
            <a href="https://www.instagram.com/p/DBodLZhg4T3/" target="_blank" class="action-link">📸 View Style Post (DBodL...)</a>
            <a href="https://www.instagram.com/p/C-_QNm3ALx7/" target="_blank" class="action-link">📸 View Style Post (C-_QN...)</a>
            <a href="https://www.instagram.com/saammrgy/" target="_blank" class="action-link">🔗 View Full Profile</a>
        </div>

        <div class="section-card">
            <div class="profile-header">
                <div class="username">AniList Database</div>
            </div>
            
            <a href="https://anilist.co/user/samrgy/animelist" target="_blank" class="action-link" style="margin-top: 0;">📊 Open Full List</a>
            
            <div style="margin-top: 15px; font-size: 0.85rem; color: var(--text-dim);">Top Tier Reads:</div>
            <div class="manga-tags">
                <span class="tag">Goodnight Punpun</span>
                <span class="tag">Boy's Abyss</span>
                <span class="tag">The Flowers of Evil</span>
            </div>
        </div>

        <footer>
            SYSTEM ONLINE // SAAMMRGY
        </footer>
    </div>

</body>
</html>
